{
  "name": "htkstudio",
  "version": "0.1.0",
  "description": "HTKstudio - visual AI workflow studio",
  "main": "electron/main.cjs",
  "author": "HTKstudio",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build:web": "vite build",
    "build:win": "npm run build:web && electron-builder --win nsis zip",
    "pack:win": "npm run build:web && electron-builder --win dir",
    "test": "npm run build:web"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "vite": "^7.1.3",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "vn.hocthietke.htkstudio",
    "productName": "HTKstudio",
    "artifactName": "HTKstudio-${version}-${arch}.${ext}",
    "directories": { "output": "release", "buildResources": "build" },
    "files": ["dist/**/*", "electron/**/*", "extension/**/*", "package.json"],
    "asar": true,
    "win": { "target": ["nsis", "zip"] },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HTKstudio",
      "runAfterFinish": true
    }
  }
}
